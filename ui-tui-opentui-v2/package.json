{
  "name": "@hermes/ui-tui-opentui-v2",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Native OpenTUI engine for Hermes (Solid + Effect-at-boundary, from scratch). Ink (ui-tui/) stays the shipping default.",
  "scripts": {
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "fmt": "prettier --write src",
    "fix": "prettier --write src && eslint . --fix",
    "test": "bun test",
    "check": "bash scripts/check.sh",
    "dev": "bun src/entry/main.tsx"
  },
  "dependencies": {
    "@opentui/core": "0.3.2",
    "@opentui/keymap": "0.3.2",
    "@opentui/solid": "0.3.2",
    "effect": "4.0.0-beta.78",
    "solid-js": "1.9.10"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "@types/bun": "latest",
    "eslint": "^9",
    "eslint-plugin-unused-imports": "^4",
    "prettier": "^3",
    "typescript": "^5",
    "typescript-eslint": "^8"
  }
}
